    "array=[64,42,50,63,34,30,32,25,27,20,23,15] \n",
    "for i in range(len(array)):\n",
    "    min=i\n",
    "    for j in range(i,len(array)-1):\n",
    "        if array[min]>array[j+1]:\n",
    "            min=j+1\n",
    "    array[i],array[min]=array[min],array[i]\n",
    "print(array)"
   ]
